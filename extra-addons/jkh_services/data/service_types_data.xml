<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Последовательности для нумерации документов -->
    <record id="seq_jkh_service_act" model="ir.sequence">
        <field name="name">Реализация услуг ЖКХ</field>
        <field name="code">jkh.service.act</field>
        <field name="prefix">РУ-%(year)s-</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <record id="seq_jkh_reconciliation_act" model="ir.sequence">
        <field name="name">Акт сверки ЖКХ</field>
        <field name="code">jkh.reconciliation.act</field>
        <field name="prefix">АС-%(year)s-</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <record id="seq_jkh_invoice" model="ir.sequence">
        <field name="name">Счёт на оплату ЖКХ</field>
        <field name="code">jkh.invoice</field>
        <field name="prefix">СЧ-%(year)s-</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <record id="seq_jkh_bank_statement" model="ir.sequence">
        <field name="name">Банковская выписка ЖКХ</field>
        <field name="code">jkh.bank.statement</field>
        <field name="prefix">ВЫП-%(year)s-</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>
</odoo>
