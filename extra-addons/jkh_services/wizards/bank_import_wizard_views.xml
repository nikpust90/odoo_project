<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_jkh_bank_import_wizard_form" model="ir.ui.view">
        <field name="name">jkh.bank.import.wizard.form</field>
        <field name="model">jkh.bank.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Импорт банковской выписки">
                <group string="Параметры импорта">
                    <field name="import_format"/>
                    <field name="journal_id"/>
                    <field name="file_data" filename="file_name" widget="binary" string="Файл выписки"/>
                    <field name="file_name"/>
                </group>
                <group string="Предпросмотр" invisible="lines_count == 0">
                    <field name="lines_count" readonly="1" string="Найдено строк"/>
                    <field name="preview_lines" readonly="1" nolabel="1" widget="text"
                           style="font-family: monospace; font-size: 11px;"/>
                </group>
                <footer>
                    <button name="action_preview" string="Предпросмотр" type="object"
                            class="btn-secondary"/>
                    <button name="action_import" string="Импортировать" type="object"
                            class="btn-primary"/>
                    <button string="Отмена" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
