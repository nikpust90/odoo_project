<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_profit" model="ir.actions.report">
        <field name="name">Отчёт по выручке</field>
        <field name="model">jkh.profit.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">jkh_services.report_profit_template</field>
        <field name="report_file">jkh_services.report_profit_template</field>
        <field name="print_report_name">'Отчёт_по_выручке'</field>
    </record>

    <template id="report_profit_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="article" style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; color:#1a1a2e; background:#fff;">

                    <style>
                        .rep-header { background:#1a2744; color:#fff; padding:26px 36px 20px; }
                        .rep-accent { height:4px; background:linear-gradient(90deg,#f39c12 0%,#1a2744 100%); }
                        .rep-body { padding:24px 36px; }
                        .rep-kpi { display:table; width:100%; border-collapse:collapse; margin-bottom:24px; }
                        .rep-kpi-cell { display:table-cell; width:25%; padding:16px; text-align:center; border:1px solid #e8edf5; border-radius:6px; }
                        .rep-kpi-val { font-size:20px; font-weight:800; color:#1a2744; }
                        .rep-kpi-label { font-size:9px; text-transform:uppercase; letter-spacing:1px; color:#9aaccc; margin-top:4px; }
                        .rep-kpi-tax { color:#f39c12; }
                        .rep-kpi-total { color:#27ae60; }
                        .rep-kpi-count { color:#4a90d9; }
                        .rep-section { font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:#f39c12; margin-bottom:8px; border-bottom:2px solid #f39c12; padding-bottom:4px; display:inline-block; }
                        .rep-tbl { width:100%; border-collapse:collapse; font-size:10px; }
                        .rep-tbl thead tr { background:#1a2744; color:#fff; }
                        .rep-tbl thead th { padding:9px 12px; font-size:9px; font-weight:600; text-transform:uppercase; letter-spacing:0.3px; border:none; }
                        .rep-tbl tbody tr { border-bottom:1px solid #eef1f8; }
                        .rep-tbl tbody tr:nth-child(even) { background:#fdfaf4; }
                        .rep-tbl tbody td { padding:8px 12px; color:#2d3748; border:none; }
                        .rep-tbl tfoot tr { background:#1a2744; color:#fff; }
                        .rep-tbl tfoot td { padding:10px 12px; font-weight:700; border:none; }
                        .bar-wrap { background:#e8edf5; border-radius:3px; height:8px; margin-top:4px; }
                        .bar-fill { background:#f39c12; border-radius:3px; height:8px; display:block; }
                        .text-right { text-align:right; }
                        .text-center { text-align:center; }
                        .chip { display:inline-block; background:#eef3ff; color:#4a90d9; font-size:8px; font-weight:700; padding:2px 7px; border-radius:10px; }
                    </style>

                    <!-- ШАПКА -->
                    <div class="rep-header">
                        <table style="width:100%; border-collapse:collapse;">
                            <tr>
                                <td style="vertical-align:middle;">
                                    <div style="font-size:22px; font-weight:700; margin:0; letter-spacing:0.4px;">
                                        ОТЧЁТ ПО ВЫРУЧКЕ
                                    </div>
                                    <div style="font-size:11px; color:#a8bcd4; margin-top:4px; text-transform:uppercase; letter-spacing:1px;">
                                        revenue report
                                    </div>
                                </td>
                                <td style="text-align:right; vertical-align:middle;">
                                    <div style="font-size:13px; color:#f39c12; font-weight:700;">
                                        <t t-esc="o.date_from" t-options='{"widget":"date"}'/> &#8212; <t t-esc="o.date_to" t-options='{"widget":"date"}'/>
                                    </div>
                                    <div style="font-size:10px; color:#a8bcd4; margin-top:4px;">
                                        <t t-esc="o.company_id.name"/>
                                    </div>
                                    <div style="font-size:9px; color:#6b7a99; margin-top:2px;">
                                        Сформирован: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d.%m.%Y %H:%M')"/>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div class="rep-accent"/>

                    <div class="rep-body">

                        <!-- KPI КАРТОЧКИ -->
                        <table style="width:100%; border-collapse:separate; border-spacing:8px; margin-bottom:20px;">
                            <tr>
                                <td style="width:25%; padding:16px; text-align:center; background:#f8faff; border:1px solid #e0e6f0; border-radius:6px; border-top:3px solid #1a2744;">
                                    <div style="font-size:18px; font-weight:800; color:#1a2744;">
                                        <t t-esc="o.total_revenue" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                    </div>
                                    <div style="font-size:9px; text-transform:uppercase; letter-spacing:1px; color:#9aaccc; margin-top:4px;">Выручка без НДС</div>
                                </td>
                                <td style="width:25%; padding:16px; text-align:center; background:#fff8f0; border:1px solid #fde8c0; border-radius:6px; border-top:3px solid #f39c12;">
                                    <div style="font-size:18px; font-weight:800; color:#f39c12;">
                                        <t t-esc="o.total_tax" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                    </div>
                                    <div style="font-size:9px; text-transform:uppercase; letter-spacing:1px; color:#c87d00; margin-top:4px;">Сумма НДС</div>
                                </td>
                                <td style="width:25%; padding:16px; text-align:center; background:#f0fff6; border:1px solid #b2dfcc; border-radius:6px; border-top:3px solid #27ae60;">
                                    <div style="font-size:20px; font-weight:800; color:#27ae60;">
                                        <t t-esc="o.total_with_tax" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                    </div>
                                    <div style="font-size:9px; text-transform:uppercase; letter-spacing:1px; color:#1a5c3a; margin-top:4px;">ИТОГО С НДС</div>
                                </td>
                                <td style="width:25%; padding:16px; text-align:center; background:#eef3ff; border:1px solid #c5d5f5; border-radius:6px; border-top:3px solid #4a90d9;">
                                    <div style="font-size:28px; font-weight:800; color:#4a90d9;">
                                        <t t-esc="o.acts_count"/>
                                    </div>
                                    <div style="font-size:9px; text-transform:uppercase; letter-spacing:1px; color:#2d5aa0; margin-top:4px;">Актов реализации</div>
                                </td>
                            </tr>
                        </table>

                        <!-- ДЕТАЛИЗАЦИЯ -->
                        <div style="font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:#f39c12; margin-bottom:8px; border-bottom:2px solid #f39c12; padding-bottom:4px; display:inline-block; margin-top:8px;">
                            Детализация
                            <t t-if="o.group_by == 'month'"> по месяцам</t>
                            <t t-if="o.group_by == 'partner'"> по контрагентам</t>
                            <t t-if="o.group_by == 'service'"> по видам услуг</t>
                        </div>

                        <table class="rep-tbl" style="margin-top:8px;">
                            <thead>
                                <tr>
                                    <th style="width:5%;" class="text-center">&#8470;</th>
                                    <th style="width:35%;">
                                        <t t-if="o.group_by == 'month'">Период</t>
                                        <t t-if="o.group_by == 'partner'">Контрагент</t>
                                        <t t-if="o.group_by == 'service'">Вид услуги</t>
                                    </th>
                                    <th class="text-center" style="width:8%;">Актов</th>
                                    <th class="text-right" style="width:18%;">Выручка без НДС</th>
                                    <th class="text-right" style="width:14%;">НДС</th>
                                    <th class="text-right" style="width:16%;">Итого с НДС</th>
                                    <th class="text-center" style="width:14%;">Доля</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.result_line_ids" t-as="line">
                                    <tr>
                                        <td class="text-center" style="color:#9aaccc; font-size:9px;">
                                            <t t-esc="line_index + 1"/>
                                        </td>
                                        <td style="font-weight:600; color:#1a2744;">
                                            <t t-esc="line.group_label"/>
                                        </td>
                                        <td class="text-center">
                                            <span style="display:inline-block; background:#eef3ff; color:#4a90d9; font-size:8px; font-weight:700; padding:2px 7px; border-radius:10px;">
                                                <t t-esc="line.acts_count"/>
                                            </span>
                                        </td>
                                        <td class="text-right" style="color:#1a2744;">
                                            <t t-esc="line.revenue" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                        </td>
                                        <td class="text-right" style="color:#f39c12;">
                                            <t t-esc="line.tax" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                        </td>
                                        <td class="text-right" style="font-weight:700; color:#27ae60;">
                                            <t t-esc="line.total_with_tax" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                        </td>
                                        <td class="text-center">
                                            <t t-if="o.total_revenue &gt; 0">
                                                <t t-set="pct" t-value="round(line.revenue / o.total_revenue * 100, 1)"/>
                                                <div style="background:#e8edf5; border-radius:3px; height:8px; margin-bottom:2px;">
                                                    <t t-set="w" t-value="int(line.revenue / o.total_revenue * 100)"/>
                                                    <span t-attf-style="background:#f39c12; border-radius:3px; height:8px; display:block; width:{{ w }}%;"/>
                                                </div>
                                                <span style="font-size:9px; color:#6b7a99;"><t t-esc="pct"/>%</span>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-right" style="color:#a8bcd4; font-weight:400; font-size:9px; letter-spacing:0.5px;">ИТОГО</td>
                                    <td class="text-right">
                                        <t t-esc="o.total_revenue" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                    </td>
                                    <td class="text-right" style="color:#f39c12;">
                                        <t t-esc="o.total_tax" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                    </td>
                                    <td class="text-right" style="font-size:13px; color:#4ae09a;">
                                        <t t-esc="o.total_with_tax" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                    </td>
                                    <td class="text-center" style="color:#a8bcd4;">100%</td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ПРИМЕЧАНИЕ ПО ФИЛЬТРАМ -->
                        <div style="margin-top:16px; padding:10px 14px; background:#f8f9fc; border-radius:6px; font-size:9px; color:#6b7a99;">
                            <strong>Параметры отчёта:</strong>
                            Период: <t t-esc="o.date_from" t-options='{"widget":"date"}'/> &#8212; <t t-esc="o.date_to" t-options='{"widget":"date"}'/>&#160;&#160;
                            Группировка:
                            <t t-if="o.group_by == 'month'">по месяцам</t>
                            <t t-if="o.group_by == 'partner'">по контрагентам</t>
                            <t t-if="o.group_by == 'service'">по видам услуг</t>&#160;&#160;
                            Статус:
                            <t t-if="o.state_filter == 'all'">все (подтверждённые, отправленные, закрытые)</t>
                            <t t-if="o.state_filter == 'confirmed'">только подтверждённые</t>
                            <t t-if="o.state_filter == 'done'">только закрытые</t>
                            <t t-if="o.partner_ids">&#160;&#160;Контрагенты: <t t-esc="', '.join(o.partner_ids.mapped('name'))"/></t>
                        </div>

                    </div>

                    <!-- НИЖНИЙ КОЛОНТИТУЛ -->
                    <div style="background:#1a2744; color:#a8bcd4; font-size:8px; padding:8px 36px; text-align:center; letter-spacing:0.5px; margin-top:28px;">
                        <t t-esc="o.company_id.name"/>
                        <t t-if="o.company_id.website"> &#183; <t t-esc="o.company_id.website"/></t>
                        <t t-if="o.company_id.email"> &#183; <t t-esc="o.company_id.email"/></t>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
